# ---------------------------------------------------------------------------
# LOCAL DEVELOPMENT ENV (file-based Postgres via PGlite)
# ---------------------------------------------------------------------------
# This project reads configuration from ambient environment variables (the
# same ones Replit injects as Secrets in production). For local development,
# copy this file to `.env.local` and load it into your shell before starting
# the app, e.g. (bash/zsh):
#
#     set -a && source .env.local && set +a
#
# Then in three terminals (all with the env loaded):
#     1) pnpm db:local                     # start the file-based Postgres
#     2) pnpm db:push                      # create tables (first time only)
#     3) pnpm --filter @workspace/api-server run dev   # API
#        pnpm --filter @workspace/time-tracker run dev # web UI
#
# See LOCAL_DEV.md for the full walkthrough.
# ---------------------------------------------------------------------------

# Local PGlite server (started by `pnpm db:local`). Identical driver + URL
# shape as Replit's Postgres, so no app code changes between local and Replit.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# PGlite is a single-connection engine — cap the node-postgres pool at 1.
# (Leave this UNSET on Replit so the normal pool default is used.)
PG_POOL_MAX=1

# API server port (Replit sets this automatically; required locally).
PORT=8080

# Admin gate + session secret — any non-empty values are fine for local dev.
APP_ACCESS_PASSWORD=dev
SESSION_SECRET=dev-secret-change-me

# ---- Optional overrides for the local DB server (scripts/src/local-db.ts) ----
# PGLITE_PORT=5432
# PGLITE_HOST=127.0.0.1
# PGLITE_DATA_DIR=./.local-pgdata
